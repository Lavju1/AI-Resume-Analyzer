APP_NAME=ai-resume-analyzer
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]
PYTHONUNBUFFERED=1
